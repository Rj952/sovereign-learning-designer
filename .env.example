# =============================================================================
# Sovereign AI Learning Designer — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# In production (Vercel), set these in: Project Settings → Environment Variables.
# Never commit .env.local — it is already in .gitignore.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Your Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Optional — model + cost controls
# -----------------------------------------------------------------------------

# Pin a specific Claude model. Defaults to the latest Sonnet your account
# can access.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Maximum tokens per request — hard cap on completions to control costs.
ANTHROPIC_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# Optional — access gate
# -----------------------------------------------------------------------------

# When ACCESS_CODE is set, the app is locked behind /unlock and requires
# this code. Leave unset to keep the app fully public.
# ACCESS_CODE=choose-something-shareable

# -----------------------------------------------------------------------------
# Optional — rate limiting (per-IP, in-memory)
# -----------------------------------------------------------------------------

# Max requests per IP per window. Default: 30.
# RATE_LIMIT_MAX=30

# Window length in milliseconds. Default: 1 hour.
# RATE_LIMIT_WINDOW_MS=3600000
