# =============================================================================
# Sovereign AI Learning Designer — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# In production (Vercel), set these in: Project Settings → Environment Variables.
# Never commit .env.local — it is already in .gitignore.

# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pin a specific Claude model.
# Defaults to the latest Sonnet your account can access.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: maximum tokens per request (safety cap to control costs).
ANTHROPIC_MAX_TOKENS=2000
